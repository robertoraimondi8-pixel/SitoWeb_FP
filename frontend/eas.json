{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fantaofficial28032026-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "bundleIdentifier": "com.fantapronostic.app"
      },
      "android": {
        "package": "com.fantapronostic.app",
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fantaofficial28032026-production.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "bundleIdentifier": "com.fantapronostic.app"
      },
      "android": {
        "package": "com.fantapronostic.app",
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fantaofficial28032026-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "robertoraimondi8@gmail.com",
        "ascAppId": "6760613936",
        "appleTeamId": "UYGWA7CLQ6"
      },
      "android": {
        "serviceAccountKeyPath": "./fantapronostic-play-key.json",
        "track": "internal"
      }
    }
  }
}
